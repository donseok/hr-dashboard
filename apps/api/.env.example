# App
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_dashboard

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hr:
REDIS_TTL=3600

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=hr-dashboard-api
KAFKA_GROUP_ID=hr-dashboard-group

# JWT
JWT_SECRET=hr-dashboard-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=hr-dashboard

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_PATH=/graphql
